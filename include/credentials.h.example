#pragma once

// WiFi
#define WIFI_SSID              "your_ssid_here"
#define WIFI_PASSWORD          "your_password_here"

// MQTT broker
#define MQTT_BROKER            "192.168.1.100"
#define MQTT_PORT              1883
#define MQTT_TOPIC             "car/focus/obd"
#define MQTT_CLIENT_ID         "ford-focus-obd"
#define MQTT_PUBLISH_INTERVAL_MS  30000   // 30 seconds

// CAN bus GPIO pins — verify against your T2-CAN board schematic
// HS-CAN → CAN0 / TWAI0
#define CAN_HS_TX_PIN          4
#define CAN_HS_RX_PIN          5

// MS-CAN → CAN1 / TWAI1
#define CAN_MS_TX_PIN          6
#define CAN_MS_RX_PIN          7

// Deep sleep — wake on MCP2515 INT (T-2CAN schematic: GPIO8)
#define CAN_INT_PIN              8
#define SLEEP_IDLE_TIMEOUT_MS    300000  // 5 minutes; both CAN buses must be silent

// OLED display (SH1106 128x64, I2C) — T-2CAN QWIIC connector
#define DISPLAY_SDA              1
#define DISPLAY_SCL              2
#define DISPLAY_INTERVAL_MS      2000    // ms between frame rotations
